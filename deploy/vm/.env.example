# --- Docker images ---
GITHUB_REPO=username/digest_tracker
FRONTEND_TAG=latest
BACKEND_TAG=latest

# --- PostgreSQL ---
POSTGRES_USER=devdigest
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=devdigest_db

# --- Redis ---
REDIS_PASSWORD=change_me_redis_password

# --- Backend app ---
JWT_SECRET=change_me_min_32_chars
JWT_REFRESH_SECRET=change_me_min_32_chars
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4-turbo-preview

# --- Telegram ---
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef...
TELEGRAM_BOT_TOKEN=...
TELEGRAM_WEBHOOK_SECRET=...
MTPROTO_ENCRYPTION_KEY=...

# --- MTProto Proxy (optional, for Telegram connectivity) ---
MTPROTO_PROXY_HOST=
MTPROTO_PROXY_PORT=
MTPROTO_PROXY_USER=
MTPROTO_PROXY_PASS=

# --- Cron ---
CRON_SECRET=...

# --- WebAuthn ---
WEBAUTHN_RP_ID=tracker.kirrrusha.ru
WEBAUTHN_RP_NAME=DevDigest
WEBAUTHN_ORIGIN=https://tracker.kirrrusha.ru
WEBAUTHN_EXTRA_ORIGINS=
