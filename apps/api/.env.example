# App
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://devdigest:devdigest_password@localhost:5432/devdigest_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4-turbo-preview

# Telegram
TELEGRAM_BOT_TOKEN=...
TELEGRAM_BOT_USERNAME=...
TELEGRAM_WEBHOOK_SECRET=...
TELEGRAM_API_ID=...
TELEGRAM_API_HASH=...

# MTProto
MTPROTO_ENCRYPTION_KEY=...

# Cron
CRON_SECRET=...

# WebAuthn / Passkey
WEBAUTHN_RP_ID=fitting-ant-light.ngrok-free.app
WEBAUTHN_RP_NAME=DevDigest
# Browser origin for web; for native mobile use android:apk-key-hash:<hash> for Android
WEBAUTHN_ORIGIN=https://fitting-ant-light.ngrok-free.app

# Native passkey (mobile)
APPLE_TEAM_ID=XXXXXXXXXX
IOS_BUNDLE_ID=com.devdigest.mobile
ANDROID_APP_FINGERPRINT=AA:BB:CC:...
# Comma-separated extra origins accepted by WebAuthn verify (Android native: android:apk-key-hash:<base64>)
WEBAUTHN_EXTRA_ORIGINS=android:apk-key-hash:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
